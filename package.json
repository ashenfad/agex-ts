{
  "name": "agex-ts-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for agex-ts and supporting libraries (@agex-ts/kvgit, @agex-ts/termish, providers).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.0.4",
  "scripts": {
    "build": "pnpm -r build",
    "check:dist": "node scripts/check-dist-shape.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec biome check --write --staged --no-errors-on-unmatched && git update-index --again"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.31.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.2"
  }
}
