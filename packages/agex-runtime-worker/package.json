{
  "name": "@agex-ts/runtime-worker",
  "version": "3.0.0",
  "description": "Worker-isolated RuntimeAdapter for agex-ts. Browser-first (Web Worker); ts-blank-space transpile by default with a transform hook for embedders that need fuller TS coverage (e.g. esbuild-wasm).",
  "keywords": [
    "agex",
    "agex-ts",
    "agent",
    "web-worker",
    "sandbox",
    "runtime",
    "isolation",
    "browser",
    "typescript"
  ],
  "author": "Adam Ashenfelter",
  "license": "MIT",
  "homepage": "https://github.com/ashenfad/agex-ts/tree/main/packages/agex-runtime-worker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashenfad/agex-ts.git",
    "directory": "packages/agex-runtime-worker"
  },
  "bugs": "https://github.com/ashenfad/agex-ts/issues",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "import": "./dist/worker.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:watch": "vitest --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev45.0",
    "@vitest/browser": "^2.1.9",
    "agex-ts": "workspace:^",
    "playwright": "^1.59.1",
    "@agex-ts/termish": "workspace:^",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "agex-ts": "workspace:^"
  },
  "dependencies": {
    "ts-blank-space": "^0.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
