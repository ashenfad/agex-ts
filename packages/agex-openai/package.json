{
  "name": "@agex-ts/openai",
  "version": "3.0.0",
  "description": "OpenAI Chat Completions provider for agex-ts. Lowers NeutralTurn[] to OpenAI messages; streams via SSE; baseUrl-friendly for OpenAI-compatible local servers (ollama, vLLM, LM Studio, OpenRouter, Together, etc.).",
  "keywords": [
    "agex",
    "agex-ts",
    "agent",
    "llm",
    "openai",
    "gpt",
    "provider",
    "ollama",
    "vllm",
    "openrouter"
  ],
  "author": "Adam Ashenfelter",
  "license": "MIT",
  "homepage": "https://github.com/ashenfad/agex-ts/tree/main/packages/agex-openai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashenfad/agex-ts.git",
    "directory": "packages/agex-openai"
  },
  "bugs": "https://github.com/ashenfad/agex-ts/issues",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "agex-ts": "workspace:^",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "agex-ts": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
