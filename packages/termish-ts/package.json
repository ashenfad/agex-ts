{
  "name": "@agex-ts/termish",
  "version": "0.1.0",
  "description": "Pure-TypeScript shell parser + builtins over an async FileSystem. TypeScript port of agex-py's termish (minus jq).",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "shell",
    "parser",
    "filesystem",
    "terminal",
    "virtual-filesystem",
    "typescript",
    "browser"
  ],
  "author": "Adam Ashenfelter",
  "license": "MIT",
  "homepage": "https://github.com/ashenfad/agex-ts/tree/main/packages/termish-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashenfad/agex-ts.git",
    "directory": "packages/termish-ts"
  },
  "bugs": "https://github.com/ashenfad/agex-ts/issues",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./glob": {
      "types": "./dist/glob.d.ts",
      "import": "./dist/glob.js"
    },
    "./fs/memory": {
      "types": "./dist/fs/memory.d.ts",
      "import": "./dist/fs/memory.js"
    },
    "./fs/real": {
      "types": "./dist/fs/real.d.ts",
      "import": "./dist/fs/real.js"
    },
    "./fs/kvgit": {
      "types": "./dist/fs/kvgit.d.ts",
      "import": "./dist/fs/kvgit.js"
    },
    "./fs/protocol": {
      "types": "./dist/fs/protocol.d.ts",
      "import": "./dist/fs/protocol.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@agex-ts/kvgit": "workspace:^",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "superjson": "^2.2.6"
  }
}
